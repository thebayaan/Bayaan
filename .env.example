# Bayaan app environment variables
# Copy this file to .env and fill in the values

# ── Bayaan Backend API ────────────────────────────────────────────────────────
# Community contributors: get the community key from CONTRIBUTING.md
# Leave blank to use the bundled reciter data instead (no API calls made)
EXPO_PUBLIC_BAYAAN_API_URL=https://api.thebayaan.com
EXPO_PUBLIC_BAYAAN_API_KEY=

# Optional killswitch endpoint. When set, the app fetches this URL on launch
# and respects `useBackendApi: false` to fall back to bundled data. Leave
# blank for forks/self-hosters — the check is skipped entirely, no request
# is made on launch.
EXPO_PUBLIC_KILLSWITCH_URL=

# ── Build identity (fork-configurable) ────────────────────────────────────────
# Apple Developer Team ID. Used by app.config.js and the withIOSTeam config
# plugin to set DEVELOPMENT_TEAM in the generated Xcode project. Forks must
# set their own; if blank the maintainer's ID is used and iOS builds will
# fail with a signing error (intentional — prevents accidental misuse).
APPLE_TEAM_ID=

# Expo / EAS project ID (UUID). Drives `expo.extra.eas.projectId` and the
# OTA updates URL. When this is blank, OTA updates are disabled entirely
# (the app does not phone home on launch). The maintainer sets this in a
# local .env. Forks wanting OTA updates must set their own EAS project ID.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Universal-link / deep-link domain. When set, registers iOS associated
# domains and Android intent filters (autoVerify) for this host so links
# like https://<domain>/quran/... open the app. Leave blank on forks to
# skip deep-link registration entirely and avoid conflicts.
EXPO_PUBLIC_ASSOCIATED_DOMAIN=

# Privacy policy URL surfaced in Info.plist / NSPrivacyPolicyURL. Forks
# MUST override this — shipping the maintainer's privacy policy in a
# different app is misleading and may violate store policies.
EXPO_PUBLIC_PRIVACY_POLICY_URL=

# ── Analytics & Crash Reporting ───────────────────────────────────────────────
# PostHog project API key (phc_*) from app.posthog.com. Hardcoded to the US cloud
# endpoint in app/_layout.tsx. Leave blank to build without analytics — capture
# calls no-op when the SDK isn't connected.
EXPO_PUBLIC_POSTHOG_API_KEY=

# Sentry DSN for crash reporting. Blank skips Sentry.init AND removes the
# @sentry/react-native/expo config plugin, so `expo prebuild` won't add the
# source-map / debug-symbol upload build phases. Forks without a DSN can
# clone → prebuild → archive with no Sentry setup.
EXPO_PUBLIC_SENTRY_DSN=

# Override the Sentry org/project slugs used by the Expo plugin when a DSN
# is set. Only needed if you point EXPO_PUBLIC_SENTRY_DSN at your own Sentry
# project. SENTRY_AUTH_TOKEN (secret, not stored here) is required for the
# source-map upload to succeed.
SENTRY_ORG=
SENTRY_PROJECT=

# Set to 'false' to disable all analytics + crash reporting without cutting a
# release. Defaults to enabled.
EXPO_PUBLIC_ANALYTICS_ENABLED=true

# ── Supabase (legacy — no longer required for core app features) ──────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
