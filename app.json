{
  "expo": {
    "name": "Bayaan",
    "slug": "Bayaan",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "bayaan",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bayaan.app",
      "buildNumber": "2",
      "icon": {
        "dark": "./assets/images/ios-dark.png",
        "light": "./assets/images/ios-light.png",
        "tinted": "./assets/images/ios-tinted.png"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to play audio.",
        "NSAppleMusicUsageDescription": "This app uses Apple Music to play audio.",
        "UILaunchStoryboardName": "SplashScreen",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.bayaan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#8dc9d6"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "native",
          "backgroundColor": "#ffffff",
          "imageResizeMode": "native",
          "imageWidth": 1000,
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#000000"
          },
          "userInterfaceStyle": "automatic"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e31ace41-2d1b-4777-8230-8c8264277d59"
      }
    }
  }
}
